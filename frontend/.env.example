# The absolute path to the local project directory you want to monitor with the Git status card.
# If this is left blank or unconfigured, the card will report "No project configured".
# If the path is invalid, it will report "Path not found".
TRACKED_PROJECT_PATH=C:\path\to\your\tracked\project

# Supabase Credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
